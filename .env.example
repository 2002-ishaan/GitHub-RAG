# ─────────────────────────────────────────────────────────────
# FinSight-RAG — Environment Variables Template
#
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your real values in .env
#   3. NEVER commit .env to git (it's in .gitignore)
#
# WHY THIS MATTERS:
#   Separating secrets from code is Rule #1 of production
#   systems. API keys in code = instant security fail in
#   any bank's code review.
# ─────────────────────────────────────────────────────────────

# --- LLM / Chat endpoint (final project, per professor's instructions) ---
# Student ID from ID.txt line 3 is used as the API key automatically.
# Override here only if needed.
# QWEN_API_KEY=your_student_id
QWEN_BASE_URL=https://rsm-8430-finalproject.bjlkeng.io/v1
LLM_MODEL=IGNORED
LLM_TEMPERATURE=0.0

# --- Embeddings endpoint (A2, per professor's instructions) ---
EMBEDDING_BASE_URL=https://rsm-8430-a2.bjlkeng.io/v1
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5

# --- ChromaDB (local vector database, saves to disk, no API needed) ---
CHROMA_PERSIST_DIR=./data/chroma_db

# --- Retrieval Settings ---
TOP_K_RETRIEVAL=10        # fetch this many candidates
TOP_K_RERANK=5            # keep this many after reranking

# --- Logging ---
LOG_LEVEL=INFO
LOG_DIR=./logs
