# ─────────────────────────────────────────────────────────────
# FinSight-RAG — Environment Variables Template
#
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your real values in .env
#   3. NEVER commit .env to git (it's in .gitignore)
#
# WHY THIS MATTERS:
#   Separating secrets from code is Rule #1 of production
#   systems. API keys in code = instant security fail in
#   any bank's code review.
# ─────────────────────────────────────────────────────────────

# --- LLM Provider: HuggingFace (free) ---
# GET YOUR FREE KEY:
#   1. Go to https://huggingface.co/settings/tokens
#   2. Click "New token" → name it "finsight-rag" → Read role is enough
#   3. Copy and paste below
HF_API_KEY=hf_your_huggingface_key_here
LLM_PROVIDER=huggingface
LLM_MODEL=mistralai/Mistral-7B-Instruct-v0.3
LLM_TEMPERATURE=0.0

# --- Embedding Model (runs locally on your machine, no API needed) ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- ChromaDB (local vector database, saves to disk, no API needed) ---
CHROMA_PERSIST_DIR=./data/chroma_db

# --- Retrieval Settings ---
TOP_K_RETRIEVAL=10        # fetch this many candidates
TOP_K_RERANK=5            # keep this many after reranking

# --- Logging ---
LOG_LEVEL=INFO
LOG_DIR=./logs
